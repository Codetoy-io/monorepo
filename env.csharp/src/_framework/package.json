{
  "name": "@wasmsharp/core",
  "version": "0.10.2",
  "exports": "./index.js",
  "types": "./index.d.ts",
  "scripts": {
    "watch": "tsc --watch",
    "build": "dotnet publish -c Release",
    "postbuild": "rm -rf ../env.csharp/src/_framework && rm -rf ./__tests__ && cp -r ./dist/net10.0/publish/wwwroot/_framework ../env.csharp/src/_framework",
    "pack:core": "cd ./dist/net10.0/publish/wwwroot/_framework && pnpm pack --pack-destination ../../../../../bin",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JakeYallop/WasmSharp.git"
  },
