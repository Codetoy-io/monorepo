  },
  "homepage": "https://github.com/JakeYallop/WasmSharp",
  "author": "JakeYallop",
  "keywords": [
    "wasm",
    "webassembly",
    "wasmsharp",
    "csharp",
    "dotnet",
    "javascript",
    "compilers",
    "roslyn",
    "analyzers"
  ],
  "license": "Apache-2.0",
